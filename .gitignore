# .gitignore racine — règles transverses uniquement.
# Les règles spécifiques vivent dans backend/.gitignore et frontend/.gitignore.

# ===== Environnement / secrets (repo-wide) =====
.env
.env.local
.env.*.local
*.local.yml

# ===== IDE — IntelliJ IDEA =====
.idea/
*.iml
*.ipr
*.iws
out/

# ===== IDE — VS Code =====
.vscode/*
!.vscode/extensions.json

# ===== macOS / OS =====
.DS_Store
.AppleDouble
.LSOverride
._*
*.swp
*.swo
Thumbs.db
